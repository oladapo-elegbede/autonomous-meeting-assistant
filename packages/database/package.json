{
  "name": "@meeting-assistant/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "type-check": "tsc --noEmit",
    "migrate:create": "npx node-pg-migrate create --migration-file-language sql",
    "migrate:up": "npx node-pg-migrate up",
    "migrate:down": "npx node-pg-migrate down",
    "migrate:redo": "npx node-pg-migrate redo"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "node-pg-migrate": "^8.0.4",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "kysely": "^0.29.2",
    "pg": "^8.22.0"
  }
}