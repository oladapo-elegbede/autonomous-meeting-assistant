# ============================================================
# Application
# ============================================================
NODE_ENV=development
PORT=3001

# ============================================================
# Database
# ============================================================
# Local: matches docker-compose.yml credentials
# Production: replace with managed PostgreSQL connection string
DATABASE_URL=postgresql://meeting_assistant:local_dev_password@localhost:5432/meeting_assistant_dev

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# CORS
# ============================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=debug

# ============================================================
# Future secrets — these will be filled in as we build features
# ============================================================
# CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# ENCRYPTION_KEY=