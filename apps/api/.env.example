# ============================================================
# Application
# ============================================================
NODE_ENV=development
PORT=3001

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql://meeting_assistant:local_dev_password@localhost:5432/meeting_assistant_dev

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# CORS
# ============================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=debug

# ============================================================
# Clerk Authentication
# ============================================================
# Get these from https://dashboard.clerk.com
# Both keys must be from the same Clerk application instance.
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk webhook signing secret (set after creating webhook in Step 9)
# CLERK_WEBHOOK_SECRET=# Webhook signing secret from Clerk dashboard → Webhooks → Endpoint# Webhook signing secret from Clerk dashboard → Webhooks → Endpoint
CLERK_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# ============================================================
# Supabase Storage
# ============================================================
# Get these from https://supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ_your_service_role_key_here
SUPABASE_STORAGE_BUCKET=meetings

# Maximum upload size in megabytes.
# Supabase free tier caps individual uploads at 50 MB.
# Raise to 500 when upgrading to Supabase Pro.
MAX_UPLOAD_SIZE_MB=50