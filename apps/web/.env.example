# ============================================================
# Public Variables — Safe to expose to the browser
# ============================================================
# Anything prefixed with NEXT_PUBLIC_ will be visible in the browser.
# NEVER put secrets here.

# URL of the API server
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL of the web app itself
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Server-only Variables — Only available on the server
# ============================================================
# These never reach the browser. Safe for secrets.
# (Will be filled in as we build features)

# CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=