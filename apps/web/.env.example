# ============================================================
# Public Variables — Safe to expose to the browser
# ============================================================

# URL of the API server
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL of the web app itself
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk publishable key (safe for the browser)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Clerk URL paths (used by ClerkProvider for redirects)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ============================================================
# Server-only Variables — Only available on the server
# ============================================================

# Clerk secret key (NEVER exposed to the browser)
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk webhook signing secret (set after creating webhook in dashboard)
# CLERK_WEBHOOK_SECRET=